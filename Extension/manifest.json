{
  "manifest_version": 3,
  "name": "RecoCareer.ai Scraper",
  "version": "1.0.0",
  "description": "Crawl job posting URLs and extract details into your RecoCareer.ai dashboard using AI.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon.png"
  },
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:3000/*"
  ]
}
