      },
      "post": {
        "tags": ["Interactive Recruiter Inbox"],
        "summary": "Log New Message into Thread",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "from": "recruiter@google.com",
                "subject": "Interview details",
