        "responses": {
          "200": {
            "description": "Update success feedback",
            "content": {
              "application/json": { "example": { "success": true, "message": "Resume updated." } }
            }
          }
        }
      }
    },
    "/resume/ats-score": {
      "post": {
        "tags": ["Resume Parser & Multi-Resume Manager"],
        "summary": "Calculate Deterministic & AI ATS Score",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "jobDescription": "Seeking a developer skilled in React, Node, and Docker."
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "ATS score details",
