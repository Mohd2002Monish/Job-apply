{
  "openapi": "3.0.3",
  "info": {
    "title": "RecoCareer.ai REST API Documentation",
    "description": "Complete interactive documentation for the entire RecoCareer.ai full-stack backend. Includes authentication, multi-resume builder, AI tailoring, tracking dashboards, scraper engines, form auto-fillers, SMTP outreach, click-tracking links, and Stripe payment systems.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local Backend API Port"
    }
  ],
  "paths": {
    "/auth/google": {
      "get": {
        "tags": ["Authentication"],
        "summary": "Initiate Google OAuth 2.0 Flow",
        "description": "Redirects the client browser to Google's authentication server to login via SSO.",
        "responses": {
          "302": { "description": "Redirect target to Google Sign-In portal" }
        }
      }
    },
    "/auth/microsoft": {
      "get": {
        "tags": ["Authentication"],
        "summary": "Initiate Microsoft OAuth 2.0 Flow",
        "description": "Redirects the client browser to Microsoft's Entra ID server to login via SSO.",
        "responses": {
          "302": { "description": "Redirect target to Microsoft Sign-In portal" }
        }
      }
    },
    "/auth/status": {
      "get": {
        "tags": ["Authentication"],
        "summary": "Retrieve Authenticated Profile Status",
        "description": "Decodes session cookie credentials and returns user details alongside limits metrics.",
        "responses": {
          "200": {
            "description": "Active session data",
            "content": {
              "application/json": {
                "example": {
                  "authenticated": true,
                  "email": "candidate@example.com",
                  "name": "Mohd Monish",
                  "picture": "/uploads/profile_pics/default.png",
                  "provider": "google",
                  "hasGoogleTokens": true,
                  "hasMicrosoftTokens": false,
                  "subscriptionTier": "pro",
                  "stripeSubscriptionId": "sub_1234abcd",
                  "aiRequestCount": 0,
                  "jobCount": 4
                }
              }
            }
          },
          "401": {
            "description": "Not logged in status",
            "content": {
              "application/json": { "example": { "authenticated": false, "user": null } }
            }
          }
        }
      }
    },
    "/auth/profile": {
      "get": {
        "tags": ["Authentication"],
        "summary": "Retrieve User Profile Details",
        "description": "Fetches target profile configurations and displays user metrics.",
        "responses": {
          "200": {
            "description": "User profile config data",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "user": {
                    "email": "candidate@example.com",
                    "name": "Mohd Monish",
                    "picture": "/uploads/profile_pics/default.png",
                    "targetProfile": {
                      "targetRole": "Software Engineer",
                      "targetLocation": "Remote",
                      "salaryExpectation": 120000,
                      "digestEnabled": true,
                      "digestFrequency": "daily"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Destroy Client Session Cookies",
        "description": "Clears active session cookie context from client browser registry.",
        "responses": {
          "200": {
            "description": "Signout feedback",
            "content": {
              "application/json": { "example": { "success": true, "message": "Logged out successfully" } }
            }
          }
        }
      }
    },
    "/auth/profile/update": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Update Profile Details & Picture",
        "description": "Saves changes to user's display parameters and uploads local profile image.",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "email": { "type": "string" },
                  "picture": { "type": "string", "format": "binary" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Save success result",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "user": {
                    "name": "Mohd Monish",
                    "email": "candidate@example.com",
                    "picture": "/uploads/profile_pics/profile_1782058528549.png"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/jobs": {
      "get": {
        "tags": ["Job Tracking Dashboard"],
        "summary": "List Tracked Jobs (Paginated + Filtered)",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 10 } },
          { "name": "search", "in": "query", "schema": { "type": "string" } },
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["saved", "applied", "opened", "interview", "offer", "rejected"] } },
          { "name": "sortBy", "in": "query", "schema": { "type": "string", "default": "createdAt:desc" } }
        ],
        "responses": {
          "200": {
            "description": "Jobs catalog response",
            "content": {
              "application/json": {
                "example": {
                  "jobs": [
                    {
                      "_id": "60d01f2f3f4f5a6b7c8d9e01",
                      "job": "Software Engineer",
                      "companyName": "Google",
                      "email": "hr@google.com",
                      "description": "We are seeking a developer...",
                      "status": "saved",
                      "statusHistory": [{ "status": "saved", "changedAt": "2026-06-21T15:00:00Z" }]
                    }
                  ],
                  "totalJobs": 1,
                  "page": 1,
                  "totalPages": 1
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Job Tracking Dashboard"],
        "summary": "Manually Track New Job Listing",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["job", "email", "description"],
                "properties": {
                  "job": { "type": "string" },
                  "companyName": { "type": "string" },
                  "email": { "type": "string" },
                  "description": { "type": "string" },
                  "hrName": { "type": "string" },
                  "templateId": { "type": "string", "default": "classic" }
                }
              },
              "example": {
                "job": "Full Stack Developer",
                "companyName": "Microsoft",
                "email": "recruiting@microsoft.com",
                "description": "Must have React, Node, and Mongoose experience.",
                "hrName": "Satya Nadella",
                "templateId": "minimal"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Job created",
            "content": {
              "application/json": {
                "example": {
                  "_id": "60d01f2f3f4f5a6b7c8d9e02",
                  "job": "Full Stack Developer",
                  "companyName": "Microsoft",
                  "email": "recruiting@microsoft.com",
                  "description": "Must have React, Node, and Mongoose experience.",
                  "status": "saved",
                  "statusHistory": [{ "status": "saved", "changedAt": "2026-06-21T15:10:00Z" }]
                }
              }
            }
          }
        }
      }
    },
    "/jobs/{id}": {
      "patch": {
        "tags": ["Job Tracking Dashboard"],
        "summary": "Modify Tracked Job Details",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "status": "applied",
                "hrName": "New HR Contact"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Update success response",
            "content": {
              "application/json": {
                "example": {
                  "_id": "60d01f2f3f4f5a6b7c8d9e01",
                  "job": "Software Engineer",
                  "status": "applied",
                  "statusHistory": [
                    { "status": "saved", "changedAt": "2026-06-21T15:00:00Z" },
                    { "status": "applied", "changedAt": "2026-06-21T15:30:00Z" }
                  ]
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Job Tracking Dashboard"],
        "summary": "Remove Job Application Tracker",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Deleted success status",
            "content": {
              "application/json": { "example": { "success": true, "message": "Job deleted successfully" } }
            }
          }
        }
      }
    },
    "/jobs/analytics": {
      "get": {
        "tags": ["Job Tracking Dashboard"],
        "summary": "Fetch Conversion Funnel Metrics",
        "responses": {
          "200": {
            "description": "Funnel analytics numbers",
            "content": {
              "application/json": {
                "example": {
                  "total": 12,
                  "applied": 8,
                  "replied": 3,
                  "responseRate": 38,
                  "avgReplyTimeHours": 48
                }
              }
            }
          }
        }
      }
    },
    "/jobs/due-followups": {
      "get": {
        "tags": ["Job Tracking Dashboard"],
        "summary": "Get Jobs Due for Follow-up Reminders",
        "responses": {
          "200": {
            "description": "List of due jobs",
            "content": {
              "application/json": {
                "example": [
                  {
                    "_id": "60d01f2f3f4f5a6b7c8d9e01",
                    "job": "Software Engineer",
                    "companyName": "Google",
                    "followUpDate": "2026-06-21T12:00:00Z",
                    "followUpStatus": "pending"
                  }
                ]
              }
            }
          }
        }
      }
    },
    "/jobs/import": {
      "post": {
        "tags": ["Job Tracking Dashboard"],
        "summary": "Import Scraped Job from Chrome Extension",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "jobTitle": "Front End Developer",
                "companyName": "Netflix",
                "location": "Los Gatos, CA",
                "description": "Hiring a web UI engineer...",
                "url": "https://linkedin.com/jobs/view/123",
                "source": "LinkedIn",
                "email": "hr@netflix.com"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Import success feedback",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "message": "Job imported successfully from extension.",
                  "jobId": "60d01f2f3f4f5a6b7c8d9e03"
                }
              }
            }
          }
        }
      }
    },
    "/jobs/extract-jd": {
      "post": {
        "tags": ["AI Parsing & Outreach Utilities"],
        "summary": "Extract Metadata from JD File (PDF/Image)",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["jdFile"],
                "properties": {
                  "jdFile": { "type": "string", "format": "binary" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Extracted details output",
            "content": {
              "application/json": {
                "example": {
                  "jobTitle": "Node.js Architect",
                  "companyName": "Amazon",
                  "hrName": "Jeff Bezos",
                  "hrEmail": "jobs@amazon.com",
                  "description": "Full Job description text..."
                }
              }
            }
          }
        }
      }
    },
    "/jobs/extract-url": {
      "post": {
        "tags": ["AI Parsing & Outreach Utilities"],
        "summary": "Extract Metadata from Job Post URL",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "url": "https://indeed.com/viewjob?jk=123"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Extracted details output",
            "content": {
              "application/json": {
                "example": {
                  "jobTitle": "React Developer",
                  "companyName": "Meta",
                  "description": "Frontend UI developer description..."
                }
              }
            }
          }
        }
      }
    },
    "/jobs/{id}/upload-jd": {
      "post": {
        "tags": ["AI Parsing & Outreach Utilities"],
        "summary": "Associate & Parse JD File to Tracked Job",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["jdFile"],
                "properties": {
                  "jdFile": { "type": "string", "format": "binary" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "File parsed and linked",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "jdFileContent": "Job details raw text...",
                  "atsAnalysis": { "score": 75, "matchSummary": "Good alignment" }
                }
              }
            }
          }
        }
      }
    },
    "/jobs/{id}/generate-cover-letter": {
      "post": {
        "tags": ["AI Parsing & Outreach Utilities"],
        "summary": "Generate Tailored Cover Letter",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
