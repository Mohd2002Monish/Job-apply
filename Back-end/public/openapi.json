              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Generated cover letter body",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "coverLetter": "Dear Hiring Manager,\n\nI am writing to express my interest..."
                }
              }
            }
          }
        }
      }
    },
    "/jobs/{id}/interview-prep": {
      "post": {
        "tags": ["AI Question Prep Simulator"],
        "summary": "Generate AI Tailored Practice Questions",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Array of 8 questions generated",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "questions": [
                    {
                      "_id": "60d01f2f3f4f5a6b7c8d9e99",
                      "question": "How do you optimize React render cycles?",
                      "type": "Technical",
                      "suggestedPoints": "- Mention useMemo & useCallback\n- Discuss React.memo profiling"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/jobs/{id}/interview-notes": {
      "patch": {
        "tags": ["AI Question Prep Simulator"],
        "summary": "Save Practice Notes / Answer Drafts",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "questionId": "60d01f2f3f4f5a6b7c8d9e99",
                "userNotes": "I use virtualization and state debouncers..."
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Draft saved success feedback",
            "content": {
              "application/json": { "example": { "success": true, "message": "Draft saved." } }
            }
          }
        }
      }
    },
    "/jobs/{id}/grade-answer": {
      "post": {
        "tags": ["AI Question Prep Simulator"],
        "summary": "Evaluate Written Practice Answer",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "questionId": "60d01f2f3f4f5a6b7c8d9e99",
                "userNotes": "I optimize renders using useMemo and memoized contexts."
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Grading feedback result",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "grade": {
                    "score": 8,
                    "aiFeedback": "Excellent mention of memoized contexts. Expand on virtualization for large lists.",
                    "improvedVersion": "A strong answer would be: In addition to useMemo..."
                  }
                }
              }
            }
          }
        }
      }
    },
